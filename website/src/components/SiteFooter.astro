---
import SiteFooterIcon from './SiteFooterIcon.astro';

const portfolio = 'https://ysskrishna.vercel.app';

const categoryLinks = [
  { label: 'Latest', href: `${portfolio}/products?latest=true` },
  { label: 'Featured', href: `${portfolio}/products?featured=true` },
  {
    label: 'Python Libraries & CLI Tools',
    href: `${portfolio}/products?category=python-libraries-and-cli-tools`,
  },
  {
    label: 'AI Apps & Assistants',
    href: `${portfolio}/products?category=ai-apps-and-assistants`,
  },
] as const;

const socialLinks = [
  { label: 'Website', href: portfolio, icon: 'globe' as const },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/ysskrishna', icon: 'linkedin' as const },
  { label: 'GitHub', href: 'https://github.com/ysskrishna', icon: 'github' as const },
  { label: 'PyPI', href: 'https://pypi.org/user/ysskrishna', icon: 'pypi' as const },
  { label: 'Product Hunt', href: 'https://www.producthunt.com/@ysskrishna', icon: 'producthunt' as const },
];
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__top">
      <div class="site-footer__meta">
        <p class="site-footer__made">
          Made with
          <svg class="site-footer__heart" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" aria-hidden="true">
            <path
              fill="currentColor"
              d="M462.3 62.6C407.5 15.9 326 24.3 275.7 76.2L256 96.5l-19.7-20.3C186.1 24.3 104.5 15.9 49.7 62.6c-62.8 53.6-66.1 149.8-9.9 207.9l193.5 199.8c12.5 12.9 32.8 12.9 45.3 0l193.5-199.8c56.3-58.1 53-154.3-9.8-207.9z"
            />
          </svg>
          by ysskrishna
        </p>
        <div class="site-footer__icons">
          {
            socialLinks.map(({ label, href, icon }) => (
              <a
                class="site-footer__icon-link"
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={label}
              >
                <SiteFooterIcon name={icon} />
              </a>
            ))
          }
        </div>
        <p class="site-footer__copyright">© 2026 ysskrishna. All rights reserved.</p>
      </div>
      <div class="site-footer__categories">
        <h3 class="site-footer__heading">Explore more projects</h3>
        <ul class="site-footer__list">
          {
            categoryLinks.map(({ label, href }) => (
              <li>
                <a class="site-footer__cat-link" href={href} target="_blank" rel="noopener noreferrer">
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</footer>
