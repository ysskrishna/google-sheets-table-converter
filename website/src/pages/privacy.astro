---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteBasePath } from '../paths';

const site = 'https://ysskrishna.github.io/google-sheets-table-converter';
const pageUrl = `${site}/privacy.html`;

const ldJson = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${site}/#website`,
      name: 'Table Converter',
      url: `${site}/`,
    },
    {
      '@type': 'WebPage',
      '@id': `${pageUrl}#webpage`,
      name: 'Privacy Policy — Table Converter',
      description:
        'Privacy Policy for Table Converter: what data the add-on accesses, how it is used, retention, and third-party sharing.',
      url: pageUrl,
      isPartOf: { '@id': `${site}/#website` },
      inLanguage: 'en',
      dateModified: '2026-04-09',
    },
  ],
};
---

<BaseLayout
  title="Privacy Policy — Table Converter"
  description="Privacy Policy for Table Converter: what data the add-on accesses, how it is used, retention, and third-party sharing."
  canonical={pageUrl}
  navKey="privacy"
  mainClass="site-main--inner"
  ogTitle="Privacy Policy — Table Converter"
  ogDescription="Privacy Policy for the Table Converter Google Sheets add-on."
  ogUrl={pageUrl}
  twitterCard="summary"
  ldJson={ldJson}
>
  <h1 class="page-title">Privacy Policy</h1>
  <p><strong>Last updated:</strong> April 9, 2026</p>

  <h2>Overview</h2>
  <p>
    Table Converter is a Google Sheets add-on that helps users import and export table-like data in the currently open
    spreadsheet (for example: CSV, HTML, Markdown, and JSON).
  </p>

  <h2>Support</h2>
  <p>
    For questions about this policy or the add-on, please visit the <a href={`${siteBasePath}support.html`}>Support page</a>.
  </p>

  <h2>Information Accessed</h2>
  <p>
    The add-on accesses spreadsheet content and metadata only for the spreadsheet currently opened by the user and only
    when the user runs an action.
  </p>
  <p>
    The add-on requests only the minimum Google permissions needed to access the currently open spreadsheet and display
    add-on interface elements inside Google Sheets.
  </p>

  <h2>How Information Is Used</h2>
  <p>
    Data is used only to provide the features requested by the user within the add-on interface (such as reading cells
    for export or writing values from an import).
  </p>
  <p>
    This add-on does not collect, store, or process personal data outside of what is necessary to perform user-requested
    actions within Google Sheets.
  </p>
  <ul>
    <li>No data is sold.</li>
    <li>No data is used for advertising.</li>
    <li>No spreadsheet content is intentionally transferred to external third-party servers by this add-on.</li>
  </ul>

  <h2>Storage and Retention</h2>
  <p>
    This add-on is designed to process data within Google services. It does not maintain a separate user database for
    spreadsheet content.
  </p>
  <p>
    Limited operational logs (such as error logs) may be generated by Google Cloud logging services for debugging and
    reliability. These logs do not intentionally include spreadsheet content, are accessed only as needed for support
    and maintenance, and are retained according to Google Cloud logging configuration and defaults.
  </p>

  <h2>Third-Party Sharing</h2>
  <p>
    This add-on does not share user spreadsheet content with third parties, except as required by law or platform
    operation by Google.
  </p>

  <h2>Security</h2>
  <p>
    Reasonable technical and organizational measures are used to protect the add-on and related project resources. No
    method of transmission or storage is fully risk-free.
  </p>

  <h2>Your Choices</h2>
  <p>You can stop using the add-on at any time by uninstalling it from Google Workspace Marketplace.</p>

  <h2>Changes to This Policy</h2>
  <p>This policy may be updated from time to time. The latest version is published on this page with an updated date.</p>
</BaseLayout>
